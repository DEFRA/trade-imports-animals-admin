{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "trade-imports-animals-admin"
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      {% if banner %}
        <div class="govuk-notification-banner {{ 'govuk-notification-banner--success' if banner.type === 'success' }}"
             role="alert" aria-labelledby="dlq-banner-title" data-module="govuk-notification-banner">
          <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="dlq-banner-title">
              {{ 'Success' if banner.type === 'success' else 'Important' }}
            </h2>
          </div>
          <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">{{ banner.text }}</p>
          </div>
        </div>
      {% endif %}

      {% if messages.length %}
        <p class="govuk-body" data-testid="dlq-count">
          Showing {{ messages.length }} of approximately {{ approximateCount }} message(s) on the dead-letter queue.
        </p>

        <form method="post" action="/dlq-events" novalidate>
          <input type="hidden" name="crumb" value="{{ crumb }}">
          <table class="govuk-table">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header" aria-label="Select">
                  <input type="checkbox" id="select-all" aria-label="Select all messages">
                </th>
                <th scope="col" class="govuk-table__header">Id</th>
                <th scope="col" class="govuk-table__header">Message group</th>
                <th scope="col" class="govuk-table__header">Receive count</th>
                <th scope="col" class="govuk-table__header">Body</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              {% for message in messages %}
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell">
                    <input type="checkbox" class="dlq-checkbox" name="ids" value="{{ message.id }}"
                           aria-label="Select message {{ message.id }}">
                  </td>
                  <td class="govuk-table__cell">{{ message.id }}</td>
                  <td class="govuk-table__cell">{{ message.messageGroupId }}</td>
                  <td class="govuk-table__cell">{{ message.receiveCount }}</td>
                  <td class="govuk-table__cell">
                    <details class="govuk-details">
                      <summary class="govuk-details__summary">
                        <span class="govuk-details__summary-text">View JSON</span>
                      </summary>
                      <div class="govuk-details__text">
                        <pre class="govuk-body-s" style="white-space: pre-wrap; word-break: break-all;">{{ message.bodyJson }}</pre>
                      </div>
                    </details>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>

          <div class="govuk-button-group">
            {{ govukButton({ text: "Replay", name: "action", value: "replay" }) }}
            {{ govukButton({ text: "Delete", name: "action", value: "delete", classes: "govuk-button--warning" }) }}
          </div>
        </form>
      {% else %}
        <p class="govuk-body">There are no messages on the dead-letter queue.</p>
      {% endif %}

    </div>
  </div>
{% endblock %}

{% block bodyEnd %}
  {{ super() }}
  <script type="module" src="{{ getAssetPath('dlq-events.js') }}"></script>
{% endblock %}