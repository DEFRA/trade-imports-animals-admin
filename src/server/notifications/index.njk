{% extends 'layouts/page.njk' %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% block content %}
  {{ appHeading({
    text: heading,
    caption: "trade-imports-animals-admin"
  }) }}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if notifications.length %}
        {% set tableRows = [] %}
        {% for n in notifications %}
          {% set row = [{ text: n.referenceNumber }] %}
          {% set tableRows = tableRows.concat([row]) %}
        {% endfor %}
        {{ govukTable({
          head: [{ text: "Reference number" }],
          rows: tableRows
        }) }}
      {% else %}
        <p class="govuk-body">There are no notifications.</p>
      {% endif %}
    </div>
  </div>
{% endblock %}
